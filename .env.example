# Grounded GraphRAG Tutor - Environment Variables
# Copy this file to .env and fill in your values
# Environment variables override settings in configs/default.yaml

# =============================================================================
# Global Settings
# =============================================================================

# Path to YAML configuration file (optional)
CONFIG_PATH=configs/default.yaml

# Enable debug mode (optional)
DEBUG=false

# =============================================================================
# Corpus Configuration
# Environment variable prefix: CORPUS_
# =============================================================================

# Name of the corpus
CORPUS_NAME=default

# Path to document source directory
CORPUS_PATH=./data

# Connector type: local, s3, web
CORPUS_CONNECTOR_TYPE=local

# =============================================================================
# Vector Store Configuration
# Environment variable prefix: VECTORSTORE_
# =============================================================================

# Vector store type: faiss, chroma
VECTORSTORE_TYPE=faiss

# Directory for vector store persistence
VECTORSTORE_PERSIST_DIRECTORY=./.vectorstore

# Collection name (used by ChromaDB)
VECTORSTORE_COLLECTION_NAME=default

# =============================================================================
# Embeddings Configuration
# Environment variable prefix: EMBEDDINGS_
# =============================================================================

# Embedding provider: openai, bedrock, local
EMBEDDINGS_PROVIDER=local

# Model name for embeddings
# - local: sentence-transformers/all-MiniLM-L6-v2
# - openai: text-embedding-3-small, text-embedding-3-large
# - bedrock: amazon.titan-embed-text-v1
EMBEDDINGS_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimension (must match model)
# - all-MiniLM-L6-v2: 384
# - text-embedding-3-small: 1536
# - text-embedding-3-large: 3072
# - titan-embed-text-v1: 1536
EMBEDDINGS_DIMENSION=384

# =============================================================================
# LLM Configuration
# Environment variable prefix: LLM_
# =============================================================================

# LLM provider: openai, bedrock, ollama
LLM_PROVIDER=openai

# Model name
# - openai: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# - bedrock: anthropic.claude-3-sonnet-20240229-v1:0
# - ollama: llama2, mistral, codellama
LLM_MODEL_NAME=gpt-4

# Temperature for generation (0.0 - 2.0)
LLM_TEMPERATURE=0.0

# Maximum tokens in response
LLM_MAX_TOKENS=1024

# =============================================================================
# Graph Configuration
# Environment variable prefix: GRAPH_
# =============================================================================

# Graph type: rag, multi_turn
GRAPH_TYPE=rag

# Maximum retry attempts for failed operations
GRAPH_MAX_RETRIES=2

# Confidence threshold below which to refuse answering (0.0 - 1.0)
GRAPH_REFUSAL_THRESHOLD=0.8

# =============================================================================
# HuggingFace / Sentence Transformers
# =============================================================================

# Use locally cached models only — skip network update checks.
# Set to 0 only if you need to download a new model version.
HF_HUB_OFFLINE=1

# =============================================================================
# API Authentication
# =============================================================================

# Bearer token for API access (required in production)
GRAPHRAG_API_KEY=your-api-key-here

# =============================================================================
# API Keys (for providers)
# =============================================================================

# OpenAI API key (required if LLM_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# AWS credentials (required if LLM_PROVIDER=bedrock or EMBEDDINGS_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

# Ollama base URL (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
